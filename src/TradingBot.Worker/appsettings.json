{
  "Bot": {
    "Environment": "Development",
    "InstanceId": "bot-local-1",
    "Symbols": [ "BTCUSDT" ],
    "RiskPerTradePct": 0.01,
    "MaxLeverage": 3
  },
  "Binance": {
    "UseTestnet": true,
    "EnableSpot": true,
    "EnableUsdmFutures": true,
    "RecvWindowSeconds": 5
  },
  "Anthropic": {
    "Model": "claude-sonnet-4-5-20250929",
    "MonthlyBudgetUsd": 60,
    "RequestsPerMinute": 10
  },
  "Telegram": {
    "Enabled": false,
    "CriticalChatId": "",
    "WarnChatId": "",
    "InfoChatId": ""
  },
  "Database": {
    "ConnectionString": null
  },
  "MarketData": {
    "Subscriptions": [
      { "Symbol": "BTCUSDT", "Interval": "5m",  "Account": "Spot" },
      { "Symbol": "BTCUSDT", "Interval": "15m", "Account": "Spot" },
      { "Symbol": "BTCUSDT", "Interval": "1h",  "Account": "Spot" }
    ],
    "BackfillBarCount": 500,
    "ChannelCapacity": 10000,
    "FlushMaxRows": 500,
    "FlushMaxAge": "00:00:02",
    "GapScanInterval": "00:05:00",
    "GapThresholdMultiplier": 2.0,
    "GapBackfillBarCount": 1000,
    "IndicatorWindowSize": 400,
    "UseSingletonMutex": false,
    "SingletonMutexName": "Global\\TradingBot.CandlePersistor",
    "RedisConnectionString": null,
    "LiveCandleKeyPrefix": "live:",
    "IndicatorKeyPrefix": "ind:"
  },
  "KeyVault": {
    "Uri": null
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http": "Warning",
        "Binance.Net": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/bot-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-ddTHH:mm:ss.fffZ} [{Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithEnvironmentName"
    ],
    "Properties": {
      "Application": "TradingBot"
    }
  },
  "AllowedHosts": "*"
}
